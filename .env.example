# Supabase — 브라우저/서버 양쪽에서 사용 (NEXT_PUBLIC_*은 클라이언트 번들에 포함됨)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Supabase service role — 서버 전용. RLS를 우회하므로 절대 NEXT_PUBLIC_으로 노출 금지
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# 관리용 토큰 — 로컬 개발에서만 사용 (CI/CD에서는 시크릿으로 주입)
# VERCEL_TOKEN=
# SUPABASE_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────
# 광고·분석 추적 (전부 선택사항 — 값이 없으면 자동 비활성/무동작)
# 광고를 켜기 전에 아래 값을 채우고 재배포하면 전환추적이 활성화된다.
# ─────────────────────────────────────────────────────────────
# GA4 측정 ID — 애널리틱스(analytics.google.com) > 관리 > 데이터 스트림
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# 구글애즈 ID — ads.google.com > 도구 > 전환 (태그의 AW-로 시작하는 값)
# NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX
# 구글애즈 전환 라벨(send_to) — 액션별 전환에서 발급되는 "AW-…/라벨" 전체 문자열
# NEXT_PUBLIC_GOOGLE_ADS_CONV_QUOTE=AW-XXXXXXXXX/xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_GOOGLE_ADS_CONV_REGISTER=AW-XXXXXXXXX/yyyyyyyyyyyyyyyy
# 네이버 프리미엄 로그분석 ID — searchad.naver.com 전환추적 스크립트의 계정값
# NEXT_PUBLIC_NAVER_WCS_ID=xxxxxxxxxxxxxxx
