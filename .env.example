# Supabase — 브라우저/서버 양쪽에서 사용 (NEXT_PUBLIC_*은 클라이언트 번들에 포함됨)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Supabase service role — 서버 전용. RLS를 우회하므로 절대 NEXT_PUBLIC_으로 노출 금지
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# 관리용 토큰 — 로컬 개발에서만 사용 (CI/CD에서는 시크릿으로 주입)
# VERCEL_TOKEN=
# SUPABASE_ACCESS_TOKEN=
